{
  "buildCommand": "bash build.sh",
  "outputDirectory": "public",
  "installCommand": null,
  "framework": null,
  "devCommand": "hugo server -D -p 1313",
  "build": {
    "env": {
      "HUGO_VERSION": "0.152.2",
      "GO_VERSION": "1.25.3",
      "NODE_VERSION": "20",
      "GOPROXY": "direct",
      "HUGO_ENV": "production"
    }
  },
  "headers": [
    {
      "source": "/.well-known/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Referrer-Policy",
          "value": "no-referrer"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://plausible.io https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: https:; connect-src 'self' https://plausible.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://buttondown.com;"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "connect.shawnyeager.com"
        }
      ],
      "destination": "https://shawnyeager.com/connect",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "nostr.shawnyeager.com"
        }
      ],
      "destination": "https://primal.net/shawn",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "shawnyeager-com.netlify.app"
        }
      ],
      "destination": "https://shawnyeager.com/:path*",
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "/connect",
      "permanent": true
    },
    {
      "source": "/encrypt",
      "destination": "/pgp",
      "permanent": true
    },
    {
      "source": "/pubkey",
      "destination": "/assets/public-key.asc",
      "permanent": false
    },
    {
      "source": "/work-with-me",
      "destination": "/connect",
      "permanent": true
    },
    {
      "source": "/5-keys-to-better-biz-dev",
      "destination": "/gone",
      "permanent": false,
      "statusCode": 410
    },
    {
      "source": "/big-wheel-keep-on-turning",
      "destination": "/gone",
      "permanent": false,
      "statusCode": 410
    },
    {
      "source": "/equipping-your-partners-for-success",
      "destination": "/gone",
